  "traits": {
    "Anima": {
      "breakpoints": [
        2,
        4,
        6
      ],
      "type": "origin",
      "description": "Tướng Anima nhận thêm Tốc Đánh. Khi thực hiện số đòn đánh nhất định, tạo ra 1 linh hồn Anima hỗ trợ chiến đấu.",
      "champions": [
        "Briar",
        "Jinx",
        "Aurora",
        "Illaoi",
        "Fiora"
      ]
    },
    "Arbiter": {
      "breakpoints": [
        2,
        4
      ],
      "type": "class",
      "description": "Khi bắt đầu trận, Arbiter ban phép cho đồng minh gần nhất. Đồng minh được buff sẽ nhận thêm Tốc Đánh và hồi Mana khi tiêu diệt.",
      "champions": [
        "Leona",
        "Zoe",
        "Diana",
        "LeBlanc"
      ]
    },
    "Bastion": {
      "breakpoints": [
        2,
        4,
        6
      ],
      "type": "class",
      "description": "Tướng Bastion nhận thêm Giáp và Kháng Phép. Mỗi vài giây, tướng có Giáp/Kháng Phép cao nhất tạo khiên cho bản thân.",
      "champions": [
        "Aatrox",
        "Poppy",
        "Jax",
        "Ornn",
        "Rammus",
        "Shen"
      ]
    },
    "Brawler": {
      "breakpoints": [
        2,
        4,
        6
      ],
      "type": "class",
      "description": "Tướng Brawler nhận thêm Máu tối đa. Brawler gây thêm sát thương dựa trên % Máu bổ sung.",
      "champions": [
        "Cho'Gath",
        "Rek'Sai",
        "Gragas",
        "Pantheon",
        "Maokai",
        "Urgot",
        "Tahm Kench"
      ]
    },
    "Bulwark": {
      "breakpoints": [
        1
      ],
      "type": "unique",
      "description": "Đặc tính riêng của Shen. Shen bảo vệ đồng minh bằng cách chặn sát thương cho họ.",
      "champions": [
        "Shen"
      ]
    },
    "Challenger": {
      "breakpoints": [
        2,
        4,
        6
      ],
      "type": "class",
      "description": "Tướng Challenger nhận thêm Tốc Đánh. Khi tiêu diệt mục tiêu, Challenger lao tới kẻ địch mới và nhận tốc đánh bổ sung.",
      "champions": [
        "Bel'Veth",
        "Jinx",
        "Diana",
        "Miss Fortune",
        "Kindred"
      ]
    },
    "Channeler": {
      "breakpoints": [
        2,
        4,
        6
      ],
      "type": "class",
      "description": "Tướng Channeler nhận thêm Sức Mạnh Kỹ Năng. Sau khi thi triển kỹ năng, tạo vùng năng lượng tăng sát thương cho đồng minh.",
