  "traits": {
    "Anima": { "breakpoints": [2, 4, 6], "type": "origin", "description": "Tướng Anima nhận thêm Tốc Đánh. Khi thực hiện số đòn đánh nhất định, tạo ra 1 linh hồn Anima hỗ trợ chiến đấu.", "champions": ["Briar", "Jinx", "Aurora", "Illaoi", "Fiora"] },
    "Arbiter": { "breakpoints": [2, 4], "type": "class", "description": "Khi bắt đầu trận, Arbiter ban phép cho đồng minh gần nhất. Đồng minh được buff sẽ nhận thêm Tốc Đánh và hồi Mana khi tiêu diệt.", "champions": ["Leona", "Zoe", "Diana", "LeBlanc"] },
    "Bastion": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Bastion nhận thêm Giáp và Kháng Phép. Mỗi vài giây, tướng có Giáp/Kháng Phép cao nhất tạo khiên cho bản thân.", "champions": ["Aatrox", "Poppy", "Jax", "Ornn", "Rammus", "Shen"] },
    "Brawler": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Brawler nhận thêm Máu tối đa. Brawler gây thêm sát thương dựa trên % Máu bổ sung.", "champions": ["Cho'Gath", "Rek'Sai", "Gragas", "Pantheon", "Maokai", "Urgot", "Tahm Kench"] },
    "Bulwark": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Shen. Shen bảo vệ đồng minh bằng cách chặn sát thương cho họ.", "champions": ["Shen"] },
    "Challenger": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Challenger nhận thêm Tốc Đánh. Khi tiêu diệt mục tiêu, Challenger lao tới kẻ địch mới và nhận tốc đánh bổ sung.", "champions": ["Bel'Veth", "Jinx", "Diana", "Miss Fortune", "Kindred"] },
    "Channeler": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Channeler nhận thêm Sức Mạnh Kỹ Năng. Sau khi thi triển kỹ năng, tạo vùng năng lượng tăng sát thương cho đồng minh.", "champions": ["Mordekaiser", "Zoe", "Miss Fortune", "Viktor", "Aurelion Sol", "Bard"] },
    "Commander": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Sona. Sona truyền cảm hứng cho đồng đội, tăng sức mạnh tổng thể.", "champions": ["Sona"] },
    "Dark Lady": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Morgana. Morgana gieo rắc bóng tối lên kẻ địch.", "champions": ["Morgana"] },
    "Dark Star": { "breakpoints": [2, 4, 6], "type": "origin", "description": "Khi tướng Dark Star bị hạ gục hoặc tiêu diệt kẻ thù, tướng Dark Star gần nhất nhận tăng sát thương, Tốc Đánh và Sức Mạnh Kỹ Năng.", "champions": ["Cho'Gath", "Lissandra", "Mordekaiser", "Kai'Sa", "Karma", "Jhin"] },
    "Divine Duelist": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Fiora. Fiora thách đấu kẻ mạnh nhất đối phương.", "champions": ["Fiora"] },
    "Doomer": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Vex. Vex gieo rắc nỗi sợ hãi lên kẻ thù.", "champions": ["Vex"] },
    "Eradicator": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Jhin. Jhin thực hiện đòn kết liễu với sát thương cực mạnh.", "champions": ["Jhin"] },
    "Factory New": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Graves. Graves sở hữu sức mạnh vũ khí đặc biệt.", "champions": ["Graves"] },
    "Fateweaver": { "breakpoints": [2, 4], "type": "class", "description": "Tướng Fateweaver dệt nên vận mệnh. Mỗi đầu vòng, ngẫu nhiên tăng chỉ số cho đồng minh. Số đồng minh được buff tăng theo mốc.", "champions": ["Caitlyn", "Twisted Fate", "Milio", "Corki"] },
    "Galaxy Hunter": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Zed. Zed xóa sổ mục tiêu ưu tiên từ bóng tối.", "champions": ["Zed"] },
    "Marauder": { "breakpoints": [2, 4], "type": "class", "description": "Tướng Marauder nhận thêm Sức Mạnh Tấn Công. Sau khi tiêu diệt kẻ thù, Marauder cướp vàng và nhận thêm buff.", "champions": ["Akali", "Bel'Veth", "Urgot", "Master Yi", "Fiora"] },
    "Mecha": { "breakpoints": [2, 4], "type": "origin", "description": "Tướng Mecha hợp nhất sức mạnh cơ giới. Tăng Sức Mạnh Tấn Công & Sức Mạnh Kỹ Năng. Khi tướng Mecha bị hạ, truyền lực cho Mecha còn lại.", "champions": ["Urgot", "Aurelion Sol", "The Mighty Mech"] },
    "Meeple": { "breakpoints": [2, 4, 6, 8], "type": "origin", "description": "Tướng Meeple triệu hồi Meeple nhỏ để chiến đấu. Meeple tăng sức mạnh theo số lượng trait kích hoạt. Ở mốc 8, đội hình cực kỳ mạnh.", "champions": ["Poppy", "Veigar", "Gnar", "Meepsie", "Fizz", "Corki", "Rammus", "Bard"] },
    "N.O.V.A.": { "breakpoints": [2, 4], "type": "origin", "description": "Tướng N.O.V.A. nhận N.O.V.A. Strike - đòn đánh đặc biệt mạnh mẽ sau khi thi triển kỹ năng một số lần. N.O.V.A. Strike gây hiệu ứng bổ sung.", "champions": ["Aatrox", "Caitlyn", "Akali", "Maokai", "Kindred"] },
    "Oracle": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Tahm Kench. Tahm Kench nhìn thấu tương lai và dự báo.", "champions": ["Tahm Kench"] },
    "Party Animal": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Blitzcrank. Blitzcrank mang không khí lễ hội vào trận đấu.", "champions": ["Blitzcrank"] },
    "Primordian": { "breakpoints": [2, 3], "type": "origin", "description": "Tướng Primordian nhận bônus nguyên tố ngẫu nhiên mỗi trận. Ở mốc 3, nhận thêm 1 bônus và tất cả bônus mạnh hơn.", "champions": ["Briar", "Rek'Sai", "Bel'Veth"] },
    "Psionic": { "breakpoints": [2, 4], "type": "origin", "description": "Tướng Psionic chia sẻ liên kết tâm linh. Khi một Psionic thi triển kỹ năng, các Psionic khác nhận thêm Mana. Sát thương kỹ năng tăng theo mốc.", "champions": ["Gragas", "Pyke", "Viktor", "Master Yi", "Sona"] },
    "Redeemer": { "breakpoints": [1], "type": "unique", "description": "Đặc tính riêng của Rhaast. Rhaast cứu chuộc linh hồn trong trận chiến.", "champions": ["Rhaast"] },
    "Replicator": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Replicator tạo bản sao nhỏ hơn của bản thân ở đầu trận. Bản sao có % chỉ số gốc, tăng theo mốc trait.", "champions": ["Lissandra", "Veigar", "Pantheon", "Lulu", "Miss Fortune", "Nami"] },
    "Rogue": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Rogue nhảy ra phía sau kẻ thù ở đầu trận. Rogue gây thêm sát thương chí mạng và nhận thêm tốc độ di chuyển.", "champions": ["Briar", "Talon", "Gwen", "Fizz", "Kai'Sa", "Riven"] },
    "Shepherd": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Shepherd hỗ trợ đồng minh bằng cách hồi máu và tạo khiên. Shepherd mạnh hơn khi đồng minh gần bên nhiều.", "champions": ["Lissandra", "Teemo", "Meepsie", "Illaoi", "LeBlanc", "Sona"] },
    "Sniper": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Sniper gây thêm sát thương dựa trên khoảng cách đến mục tiêu. Càng xa càng mạnh.", "champions": ["Ezreal", "Gnar", "Samira", "Xayah", "Jhin"] },
    "Space Groove": { "breakpoints": [2, 4, 6], "type": "origin", "description": "Tướng Space Groove lên 'Groove'. Trong Groove, tướng nhận thêm sát thương và giảm sát thương chịu. Groove lan truyền khi tiêu diệt kẻ thù.", "champions": ["Nasus", "Teemo", "Gwen", "Ornn", "Samira", "Nami", "Blitzcrank"] },
    "Stargazer": { "breakpoints": [2, 4, 6], "type": "origin", "description": "Tướng Stargazer nhìn vào các vì sao. Ở đầu trận, kẻ thù bị giảm Tốc Đánh. Stargazer nhận thêm Sức Mạnh Kỹ Năng.", "champions": ["Talon", "Twisted Fate", "Jax", "Lulu", "Nunu", "Xayah"] },
    "Timebreaker": { "breakpoints": [2, 4], "type": "origin", "description": "Tướng Timebreaker bẻ cong thời gian. Nhận thêm Tốc Đánh, và sau khi thi triển kỹ năng, thời gian chậm lại cho kẻ thù xung quanh.", "champions": ["Ezreal", "Milio", "Pantheon", "Riven"] },
    "Vanguard": { "breakpoints": [2, 4, 6], "type": "class", "description": "Tướng Vanguard nhận thêm Giáp. Khi nhận sát thương, Vanguard tạo lá chắn cho đồng minh gần nhất.", "champions": ["Leona", "Nasus", "Mordekaiser", "Illaoi", "Nunu", "Blitzcrank"] },
    "Voyager": { "breakpoints": [2, 4], "type": "class", "description": "Tướng Voyager du hành giữa các vì sao. Ở đầu vòng, Voyager nhận Mana bổ sung. Khi thi triển kỹ năng, teleport tới vị trí tối ưu.", "champions": ["Meepsie", "Pyke", "Aurora", "Karma", "The Mighty Mech"] }
  },
